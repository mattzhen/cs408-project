<div class="table-responsive">
  <table class="table table-striped table-hover">
    <thead>
      <tr>
        <th>Item Name</th>
        <th>Quantity</th>
        <th>Price Per Unit</th>
        <th>Obtained</th>
        <th>More info</th>
      </tr>
    </thead>
    <tbody>
      <% groceries.forEach((item) => { %>
        <tr>
          <td><%= item.item_name %></td>
          <td><%= item.quantity %></td>
          <td><%= item.price ? '$' + item.price.toFixed(2) : 'N/A' %></td>
          <td><%= item.was_obtained ? 'Yes' : 'No' %></td>
          <td>
            <a href="/item-details/<%= item.item_id %>" class="btn btn-dark btn-sm">View More</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<a href="/add-item" class="btn btn-dark my-3">Add more items</a>

<p id="totalCost" class="mb-0 mt-2 fs-5">Total before tax: <%= total ? '$' + total.toFixed(2) : '$0.00' %></p>
<% if (hasNull) { %>
  <small id="nullWarning" class="text-warning">* Some items are missing a price and are not included in the total.</small>
<% } %>
<div class="d-flex align-items-center gap-2">
  <p class="mb-0 fs-5">Done shopping?</p>
  <form action="/delete-obtained" method="POST" onsubmit="return confirm('Are you sure?')">
    <button type="submit" class="btn btn-danger">Delete Obtained Items</button>
  </form>
</div>