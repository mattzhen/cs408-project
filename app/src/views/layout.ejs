<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Cabin:wght@400;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body class="d-flex flex-column min-vh-100">
  <header>
    <nav class="navbar d-flex justify-content-between mx-2">
        <a class="navbar-brand p-2" href="/">My Grocery List</a>
        <div>
          <ul class="nav navbar-right">
            <li><a class="nav-link" href="/">Home</a></li>
            <% if (isLoggedIn) { %>
              <li><a class="nav-link" href="/groceries">View List</a></li>
              <li><a class="nav-link" href="/add-item">Add to List</a></li>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                  Account
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a class="dropdown-item" href="/signout">Sign Out</a></li>
                  <li><a class="dropdown-item" href="/delete-account">Delete Account</a></li>
                </ul>
              </li>
            <% } %>
          </ul>
        </div>
    </nav>
  </header>

  <main class="container py-4 flex-grow-1">
    <%- body %>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <footer class="border-top mt-5">
    <div class="container py-3">
      <p>Created for CS408, Spring 2026</p>
    </div>
  </footer>
</body>
</html>