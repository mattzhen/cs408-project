<h2>Additional Item Details</h2>

<% if (item) { %>
  <dl class="row">
    <dt class="col-sm-3">Item:</dt>
    <dd class="col-sm-9"><%= item.item_name %></dd>

    <dt class="col-sm-3">Requested Amount:</dt>
    <dd class="col-sm-9"><%= item.quantity %></dd>

    <dt class="col-sm-3">Brand:</dt>
    <dd class="col-sm-9"><%= item.brand ? item.brand : 'Unknown' %></dd>

    <dt class="col-sm-3">Section:</dt>
    <dd class="col-sm-9"><%= item.section %></dd>

    <dt class="col-sm-3">Obtained:</dt>
    <dd class="col-sm-9"><%= item.was_obtained ? 'Yes' : 'No' %></dd>
  </dl>
  <p id="totalCost" class="mb-0 fs-5">Total: <%= total != 0 ? '$' + total.toFixed(2) : 'Unknown price data' %></p>

  <div class="d-flex gap-2 mt-3">
    <form action="/item-details/<%= itemId %>/toggle" method="POST">
      <button type="submit" class="btn btn-success">Mark Obtained</button>
    </form>
    <form action="/item-details/<%= itemId %>/delete" method="POST">
      <button type="submit" class="btn btn-danger">Delete Item</button>
    </form>
  </div>
<% } %>