<form action="/add-item" method="POST">
  <div class="mb-3">
    <label for="item_name" class="form-label">Item Name</label>
    <input type="text" class="form-control" id="item_name" name="item_name" required>
  </div>

  <div class="mb-3">
    <label for="quantity" class="form-label">Quantity</label>
    <input type="number" class="form-control" id="quantity" name="quantity" min="1" required>
  </div>

  <div class="mb-3">
    <label for="section" class="form-label">Section</label>
    <input type="text" class="form-control" id="section" name="section" required>
  </div>

  <div class="mb-3">
    <label for="cost" class="form-label">Cost <span class="text-muted">(optional)</span></label>
    <input type="number" class="form-control" id="cost" name="cost" min="0" step="0.01">
  </div>

  <div class="mb-3">
    <label for="brand" class="form-label">Brand <span class="text-muted">(optional)</span></label>
    <input type="text" class="form-control" id="brand" name="brand">
  </div>

  <button type="submit" class="btn btn-secondary">Add Item</button>
</form>